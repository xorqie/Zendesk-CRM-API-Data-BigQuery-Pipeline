# Copy this file to `.env` and fill in your own values.
# Never commit your actual `.env` file - it is already excluded via .gitignore.

# --- Zendesk ---
# Your Zendesk subdomain, e.g. for https://acme.zendesk.com it's "acme"
ZENDESK_SUBDOMAIN=your-subdomain
# The email address of the Zendesk agent account the API token belongs to
ZENDESK_EMAIL=your-agent@example.com
# Generate this from Zendesk Admin Center: Apps and integrations -> APIs -> Zendesk API
ZENDESK_API_TOKEN=your-zendesk-api-token

# --- Google BigQuery ---
BQ_PROJECT_ID=your-gcp-project-id
BQ_DATASET_ID=zendesk
BQ_USERS_TABLE=users
BQ_TICKETS_TABLE=tickets
BQ_CSAT_TABLE=csat
BQ_KPI_TABLE=ticket_metrics

# Path to your GCP service account JSON key file (needs BigQuery Data Editor
# and BigQuery Job User roles at minimum)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# How many days of ticket history the tickets pipeline backfills/syncs
TICKETS_LOOKBACK_DAYS=180

# How many rows are staged per chunk during large exports
UPLOAD_CHUNK_SIZE=1000
